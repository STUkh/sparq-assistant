{
  "mcpServers": {
    "testrail": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@bun913/mcp-testrail@0.17.2"],
      "env": {
        "TESTRAIL_BASE_URL": "${TESTRAIL_BASE_URL}",
        "TESTRAIL_USERNAME": "${TESTRAIL_USERNAME}",
        "TESTRAIL_API_KEY": "${TESTRAIL_API_KEY}"
      }
    }
  }
}
