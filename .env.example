# .env.example — committed template, NO real secrets here
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Load before launching Claude Code:
#   source .env && claude
#
# Or use direnv (recommended for teams):
#   direnv allow
#
# Run `npx sparq-assistant doctor` to verify all credentials are loaded.
# Full setup guide: docs/SETUP.md

# ── TestRail ─────────────────────────────────────────────────────────────────
# Required when: outputs.tms.provider = "testrail" in sparq.config.json
# Base URL: your TestRail instance URL (no trailing slash)
# API key: TestRail > My Settings > API Keys > Add Key
TESTRAIL_BASE_URL=https://yourteam.testrail.io
TESTRAIL_USERNAME=your.email@company.com
TESTRAIL_API_KEY=your-api-key-here

# ── Qase ─────────────────────────────────────────────────────────────────────
# Required when: outputs.tms.provider = "qase"
# API token: https://app.qase.io > Workspace Settings > API tokens
QASE_API_TOKEN=your-qase-api-token-here

# ── Zephyr Scale (Jira Cloud add-on) ─────────────────────────────────────────
# Required when: outputs.tms.provider = "zephyr"
# API token: Jira > Settings > Apps > Zephyr Scale > API tokens
# Project key: the Jira project key (e.g. EP for tickets EP-1, EP-2...)
ZEPHYR_API_TOKEN=your-zephyr-api-token-here
ZEPHYR_PROJECT_KEY=MYPROJECT

# ── Atlassian (Jira + Confluence) ────────────────────────────────────────────
# No env vars needed — authentication is handled via OAuth by Claude Code
# on first connection. Run /mcp in Claude Code to authenticate.

# ── Figma ─────────────────────────────────────────────────────────────────────
# No env vars needed — OAuth only. Run /mcp in Claude Code to authenticate.

# ── Playwright ───────────────────────────────────────────────────────────────
# No credentials needed.
